APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Opcjonalnie: druga baza (np. certgen) — patrz config/database.php (DB_SECOND_*)
# Baza użytkowników pnedu.pl — te same host/user co DB_*, inna nazwa bazy (jak w projekcie pnedu)
# DB_PNEDU_HOST=mysql
# DB_PNEDU_PORT=3306
# DB_PNEDU_DATABASE=pnedu
# DB_PNEDU_USERNAME=sail
# DB_PNEDU_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# Poczta — lokalnie (Sail + Mailpit: http://localhost:8026)
# =============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=info@system.pnedu.pl
MAIL_FROM_NAME="Platforma Nowoczesnej Edukacji"
MAIL_SYSTEM_MAILER=log
MAIL_SYSTEM_FROM_ADDRESS=info@system.pnedu.pl
MAIL_SYSTEM_FROM_NAME="Platforma Nowoczesnej Edukacji"
MAIL_SYSTEM_REPLY_TO_ADDRESS=kontakt@pnedu.pl
MAIL_SYSTEM_REPLY_TO_NAME="Platforma Nowoczesnej Edukacji"
MAIL_BRAND_PUBLIC_URL=https://pnedu.pl
MAIL_BRAND_PUBLIC_LABEL=www.pnedu.pl

# =============================================================================
# Poczta — PRODUKCJA adm.pnedu.pl (Amazon SES, region Frankfurt)
# Oba MAIL_* muszą być ses — inaczej część maili może trafiać tylko do logu Laravel.
# Po zmianie: php artisan config:clear
# =============================================================================
# MAIL_MAILER=ses
# MAIL_SYSTEM_MAILER=ses
# MAIL_FROM_ADDRESS=info@system.pnedu.pl
# MAIL_FROM_NAME="NODN Platforma Nowoczesnej Edukacji"
# MAIL_SYSTEM_FROM_ADDRESS=info@system.pnedu.pl
# MAIL_SYSTEM_FROM_NAME="NODN Platforma Nowoczesnej Edukacji"
# MAIL_SYSTEM_REPLY_TO_ADDRESS=kontakt@pnedu.pl
# MAIL_SYSTEM_REPLY_TO_NAME="NODN Platforma Nowoczesnej Edukacji"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# Przypomnienia o wygaśnięciu dostępu (nagrania / materiały, płatne szkolenia)
# =============================================================================
PARTICIPANT_ACCESS_EXPIRY_REMINDERS_ENABLED=true
# Dni przed wygaśnięciem (kalendarz Europe/Warsaw), np. 7 i 1 = tydzień oraz dzień wcześniej
PARTICIPANT_ACCESS_EXPIRY_REMINDER_DAYS=7,1
PARTICIPANT_ACCESS_EXPIRY_REMINDER_TIMEZONE=Europe/Warsaw
PARTICIPANT_ACCESS_EXPIRY_REMINDER_TIME=08:00

VITE_APP_NAME="${APP_NAME}"


# Sendy Configuration
SENDY_API_KEY=QWVN3gYyibFsPWh39Til
SENDY_BASE_URL=https://sendyhost.net
SENDY_LICENSE_KEY=1ZmYIrF8HC93FNIcfkHCSKAcM0Tx3iVV
SENDY_PAID_TRAININGS_LIST_ID=dncdl0kfUMnk43BysMa892NQ
SENDY_CACHE_ENABLED=true
SENDY_CACHE_TTL=300
SENDY_LOGGING_ENABLED=true
SENDY_LOG_LEVEL=info
SENDY_LOG_CHANNEL=daily

# Google Calendar API (wspólny kalendarz zespołu — domyślnie wyłączone)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
# GOOGLE_CALENDAR_CREDENTIALS: absolutna ścieżka lub względna od katalogu projektu, np. storage/app/private/google/plik.json
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_TIMEZONE=Europe/Warsaw
GOOGLE_CALENDAR_COLOR_ID_ONLINE=9
GOOGLE_CALENDAR_COLOR_ID_OFFLINE=5
GOOGLE_CALENDAR_COLOR_ID_FREE=10
GOOGLE_CALENDAR_REMINDER_MINUTES=60

