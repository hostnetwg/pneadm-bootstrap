# Konfiguracja dla scripts/deploy-assets.sh
#
# Skopiuj ten plik jako scripts/deploy-assets.env i uzupełnij własne wartości.
# Plik scripts/deploy-assets.env nie jest commitowany (jest w .gitignore).

# SSH user@host (najlepiej alias z ~/.ssh/config, np. "pnedu-prod")
REMOTE_SSH="srv66127@h30.seohost.pl"

# Pełna ścieżka na serwerze do katalogu public/build (BEZ slasha na końcu).
# Aby ją sprawdzić: zaloguj się SSH-em, wejdź do pneadm-bootstrap i wpisz `pwd`,
# potem dopisz "/public/build".
REMOTE_PATH="/home/srv66127/domains/adm.pnedu.pl/pneadm-bootstrap/public/build"
